APP_NAME=CLSU-FHES
APP_ENV=local
APP_KEY=base64:YOUR_GENERATED_KEY_HERE_32BYTES
# Run `php artisan key:generate` to generate APP_KEY - CRITICAL for encryption!
# VPS Hostinger: Ensure php-openssl extension enabled (php -m | grep openssl)

APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost

# Database - adjust for VPS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clsu_fhes
DB_USERNAME=root
DB_PASSWORD=

# VPS Hostinger MySQL config here

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Encryption requires APP_KEY and openssl!
# Test: php artisan tinker 'crypt encrypt("test")' - should not error
